<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card card-auth p-4 text-center">
      <h1 class="display-5 text-danger fw-bold mb-2"><%= err.statusCode || 500 %></h1>
      <h4 class="mb-3"><%= err.message || "Something went wrong" %></h4>
      <p class="text-muted mb-4 text-small">
        The page you are looking for might have been removed, had its name changed,
        or is temporarily unavailable.
      </p>
      <a href="/listings" class="btn btn-primary btn-pill px-4">Back to Listings</a>
    </div>
  </div>
</div>
