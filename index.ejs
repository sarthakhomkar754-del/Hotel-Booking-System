<% layout('layouts/boilerplate') %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h3 class="fw-bold mb-0">Explore Hotels</h3>
    <p class="text-muted mb-0 text-small">Find your perfect stay and book in a few clicks.</p>
  </div>
  <% if (isAdmin) { %>
  <a href="/listings/new" class="btn btn-primary btn-pill btn-sm">
    <i class="fa-solid fa-plus me-1"></i> Add Listing
  </a>
  <% } %>
</div>

<form class="row g-2 mb-4" method="GET" action="/listings">
  <div class="col-12 col-md-8">
    <input
      type="text"
      name="q"
      class="form-control"
      placeholder="Search by hotel name, city, state or country..."
      value="<%= typeof q !== 'undefined' ? q : '' %>"
    />
  </div>
  <div class="col-6 col-md-2">
    <button type="submit" class="btn btn-primary w-100 btn-pill">Search</button>
  </div>
  <div class="col-6 col-md-2">
    <a href="/listings" class="btn btn-outline-light-grey w-100 btn-pill">Clear</a>
  </div>
</form>

<% if (q && listings.length === 0) { %>
  <p class="text-muted text-small">
    No hotels found for "<strong><%= q %></strong>". Try a different keyword.
  </p>
<% } %>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% listings.forEach(listing => { %>
  <div class="col">
    <div class="card card-listing h-100">
      <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
        <img
          src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/600x400?text=Hotel' %>"
          class="card-img-top card-listing-img"
          alt="<%= listing.title %>"
        />
        <div class="card-body card-listing-body">
          <h5 class="card-listing-title"><%= listing.title %></h5>
          <p class="mb-1 text-muted text-small">
            <i class="fa-solid fa-location-dot me-1"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>
          <p class="card-listing-price mb-0">
            <strong>₹ <%= listing.price.toLocaleString("en-IN") %></strong> / night
          </p>
        </div>
      </a>
    </div>
  </div>
  <% }) %>
</div>
