<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card card-auth p-4">
      <h4 class="auth-title mb-3 text-center">Welcome back</h4>

      <% if (errorMessage) { %>
      <div class="alert alert-danger py-2 text-small"><%= errorMessage %></div>
      <% } %>

      <form method="POST" action="/login" class="needs-validation" novalidate>
        <div class="mb-2">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" required />
          <div class="invalid-feedback">Please enter your email.</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" required />
          <div class="invalid-feedback">Please enter your password.</div>
        </div>

        <button type="submit" class="btn btn-primary btn-pill w-100 mb-2">
          Login
        </button>

        <p class="text-small text-center mb-0">
          New to HevenHeights?
          <a href="/register">Create an account</a>
        </p>
      </form>
    </div>
  </div>
</div>
