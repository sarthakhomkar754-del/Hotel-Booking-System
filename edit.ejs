<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card card-auth p-4">
      <h4 class="auth-title mb-3 text-center">Edit Listing</h4>

      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate>
        <div class="mb-2">
          <label class="form-label">Title</label>
          <input type="text" name="listing[title]" class="form-control" value="<%= listing.title %>" required />
        </div>

        <div class="mb-2">
          <label class="form-label">Description</label>
          <textarea name="listing[description]" rows="2" class="form-control" required><%= listing.description %></textarea>
        </div>

        <div class="mb-2">
          <label class="form-label">Image URL</label>
          <input
            type="text"
            name="listing[image][url]"
            class="form-control"
            value="<%= listing.image && listing.image.url ? listing.image.url : '' %>"
          />
        </div>

        <div class="row">
          <div class="col-md-6 mb-2">
            <label class="form-label">Price per Night</label>
            <input type="number" name="listing[price]" class="form-control" value="<%= listing.price %>" required />
          </div>
          <div class="col-md-6 mb-2">
            <label class="form-label">Country</label>
            <input type="text" name="listing[country]" class="form-control" value="<%= listing.country %>" required />
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Location</label>
          <input type="text" name="listing[location]" class="form-control" value="<%= listing.location %>" required />
        </div>

        <div class="d-flex justify-content-between">
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-light-grey btn-pill">Cancel</a>
          <button type="submit" class="btn btn-primary btn-pill">Update</button>
        </div>
      </form>

      <hr class="my-3" />

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Delete this listing?');">
        <button type="submit" class="btn btn-danger btn-pill w-100">Delete Listing</button>
      </form>
    </div>
  </div>
</div>
