<% layout("layouts/boilerplate") %>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-6">
      <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://via.placeholder.com/800x500?text=Hotel' %>" class="img-fluid rounded shadow" alt="<%= listing.title %>">
    </div>

    <div class="col-md-6">
      <h2 class="fw-bold">
        <%= listing.title %>
      </h2>
      <p class="text-muted mb-1">
        <%= listing.location %>, <%= listing.country %>
      </p>
      <h4 class="mt-2 text-primary">₹ <%= listing.price %> / night</h4>
      <p class="mt-3">
        <%= listing.description %>
      </p>

      <% if (isAdmin) { %>
        <div class="d-flex gap-2 mb-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary btn-pill btn-sm">
            <i class="fa-solid fa-pen-to-square me-1"></i> Edit Listing
          </a>
          <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
            onsubmit="return confirm('Delete this listing?');"
          >
            <button type="submit" class="btn btn-outline-danger btn-pill btn-sm">
              <i class="fa-solid fa-trash me-1"></i> Delete
            </button>
          </form>
        </div>
      <% } %>

      <hr>

      <% if (!currentUser) { %>
        <div class="login-warning-box">
          <h3 class="login-warning-title">🔒 Login Required</h3>
          <p class="login-warning-text">
            Please <a href="/login">Login</a> or
            <a href="/register">Create an Account</a>
            to book this hotel.
          </p>

          <div class="login-warning-buttons">
            <a href="/login" class="btn-login">Login</a>
            <a href="/register" class="btn-register">Create Account</a>
          </div>
        </div>
      <% } else if (!isAdmin) { %>
        <form action="/listings/<%= listing._id %>/book" method="POST" class="mt-3">
          <div class="mb-3">
            <label class="form-label fw-bold">Check-in Date</label>
            <input type="date" class="form-control" name="checkIn" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Check-out Date</label>
            <input type="date" class="form-control" name="checkOut" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Guests</label>
            <input type="number" class="form-control" name="guests" min="1" required>
          </div>

          <button class="btn btn-primary w-100 mt-2">Book Now</button>
        </form>
      <% } %>
    </div>
  </div>
</div>
